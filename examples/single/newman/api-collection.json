                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains new user ID', function () {",
                  "    var user = pm.response.json();",
                  "    pm.expect(user).to.have.property('id');",
                  "    pm.expect(user.name).to.eql('Test User');",
